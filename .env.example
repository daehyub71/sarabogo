# 살아보고 환경변수 예시. 실제 값은 .env.local에 넣고 절대 커밋하지 않는다.

# ── LLM (Q1 확정: Claude) ──
LLM_PROVIDER=anthropic          # anthropic | openai
ANTHROPIC_API_KEY=              # 기본 공급자
OPENAI_API_KEY=                 # 대체 어댑터용 (선택)

# ── 관광공사 · 심평원 (서버 전용) ──
TOUR_API_KEY=                   # 공공데이터포털 관광공사 TourAPI 4.0 인증키
HIRA_API_KEY=                   # 심평원 병원/약국

# ── 카카오 ──
KAKAO_REST_API_KEY=             # 로컬/지오코딩 (서버)
KAKAO_JS_KEY=                   # 맵 JS SDK (클라이언트, 도메인 제한 필수)

# ── 구글 (평판 참고용, 실시간 조회만) ──
GOOGLE_PLACES_KEY=

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=      # 서버·배치 전용. 클라이언트 노출 금지.
